# Delivery Companies API Keys
# ===========================
# WARNING: NEVER hardcode these keys directly in the frontend files!
# These keys are used by Vite when building the app. Add your actual keys in a .env file locally.

# Yalidine API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gemini API Keys for Rotation Pool (1..50)
GEMINI_API_KEY_1=your-gemini-key-1
GEMINI_API_KEY_2=your-gemini-key-2
# ...
GEMINI_API_KEY_20=your-gemini-key-20

# ZR Express API
VITE_ZREXPRESS_API_KEY=your_zr_express_api_key_here
