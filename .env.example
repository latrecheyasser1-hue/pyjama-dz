# Delivery Companies API Keys
# ===========================
# WARNING: NEVER hardcode these keys directly in the frontend files!
# These keys are used by Vite when building the app. Add your actual keys in a .env file locally.

# Yalidine API
VITE_YALIDINE_API_ID=your_yalidine_api_id_here
VITE_YALIDINE_API_TOKEN=your_yalidine_api_token_here

# ZR Express API
VITE_ZREXPRESS_API_KEY=your_zr_express_api_key_here
